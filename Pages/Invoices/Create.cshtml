@page
@model InvoiceApp.Pages.Invoices.CreateModel

<h2 class="text-center mb-3">Create Invoice</h2>

@if (!ViewData.ModelState.IsValid)
{
    <div class="alert alert-danger">
        Please check the form. At least one invoice item is required.
    </div>
}

<form method="post">
    <div class="row g-2 mb-3">
        <div class="col-lg-6">
            <div class="card h-100 border-0 shadow-sm">
                <div class="card-header bg-white fw-semibold">Invoice Details</div>
                <div class="card-body">

                    <div class="row mb-3">
                        <label class="col-sm-4 col-form-label">Invoice Number</label>
                        <div class="col-sm-8">
                            <input class="form-control" asp-for="InvoiceDto.Number" />
                        </div>
                    </div>

                    <div class="row mb-3">
                        <label class="col-sm-4 col-form-label">Status</label>
                        <div class="col-sm-8">
                            <select class="form-select" asp-for="InvoiceDto.Status">
                                <option value="Pending">Pending</option>
                                <option value="Paid">Paid</option>
                            </select>
                        </div>
                    </div>

                    <div class="row mb-3">
                        <label class="col-sm-4 col-form-label">Issue Date</label>
                        <div class="col-sm-8">
                            <input class="form-control" asp-for="InvoiceDto.IssueDate" type="date" />
                        </div>
                    </div>

                    <div class="row mb-3">
                        <label class="col-sm-4 col-form-label">Due Date</label>
                        <div class="col-sm-8">
                            <input class="form-control" asp-for="InvoiceDto.DueDate" type="date" />
                        </div>
                    </div>

                </div>
            </div>
        </div>

        <div class="col-lg-6">
            <div class="card h-100 border-0 shadow-sm">
                <div class="card-header bg-white fw-semibold">Client Details</div>
                <div class="card-body">

                    <div class="row mb-3">
                        <label class="col-sm-4 col-form-label">Client Name</label>
                        <div class="col-sm-8">
                            <input class="form-control" asp-for="InvoiceDto.ClientName" />
                        </div>
                    </div>

                    <div class="row mb-3">
                        <label class="col-sm-4 col-form-label">Email</label>
                        <div class="col-sm-8">
                            <input class="form-control" asp-for="InvoiceDto.Email" />
                        </div>
                    </div>

                    <div class="row mb-3">
                        <label class="col-sm-4 col-form-label">Phone</label>
                        <div class="col-sm-8">
                            <input class="form-control" asp-for="InvoiceDto.Phone" />
                        </div>
                    </div>

                    <div class="row mb-3">
                        <label class="col-sm-4 col-form-label">Address</label>
                        <div class="col-sm-8">
                            <input class="form-control" asp-for="InvoiceDto.Address" />
                        </div>
                    </div>

                </div>
            </div>
        </div>
    </div>

    <div class="card mb-3 border-0 shadow-sm">
        <div class="card-header bg-white d-flex justify-content-between align-items-center">
            <span class="fw-semibold">Invoice Items</span>

            <button type="button" class="btn btn-outline-primary btn-sm" onclick="addItemRow()">
                + Add Item
            </button>
        </div>

        <div class="card-body">
            <div class="table-responsive">
                <table class="table align-middle" id="itemsTable">
                    <thead class="table-light">
                        <tr>
                            <th style="width: 40%">Service</th>
                            <th style="width: 20%">Unit Price</th>
                            <th style="width: 15%">Quantity</th>
                            <th style="width: 15%">Total</th>
                            <th style="width: 10%"></th>
                        </tr>
                    </thead>

                    <tbody id="itemsBody">
                        @for (int i = 0; i < Model.InvoiceDto.Items.Count; i++)
                        {
                            <tr>
                                <td>
                                    <input class="form-control"
                                           name="InvoiceDto.Items[@i].Service"
                                           value="@Model.InvoiceDto.Items[i].Service" />
                                </td>

                                <td>
                                    <input class="form-control unit-price"
                                           name="InvoiceDto.Items[@i].UnitPrice"
                                           value="@Model.InvoiceDto.Items[i].UnitPrice.ToString("0.00", System.Globalization.CultureInfo.InvariantCulture)"
                                           type="number"
                                           step="0.01"
                                           min="0"
                                           oninput="updateTotals()" />
                                </td>

                                <td>
                                    <input class="form-control quantity"
                                           name="InvoiceDto.Items[@i].Quantity"
                                           value="@Model.InvoiceDto.Items[i].Quantity"
                                           type="number"
                                           step="1"
                                           min="1"
                                           oninput="updateTotals()" />
                                </td>

                                <td>
                                    <input class="form-control row-total" disabled />
                                </td>

                                <td>
                                    <button type="button" class="btn btn-outline-danger btn-sm" onclick="removeItemRow(this)">
                                        Remove
                                    </button>
                                </td>
                            </tr>
                        }
                    </tbody>

                    <tfoot>
                        <tr>
                            <td colspan="3" class="text-end fw-bold">Grand Total</td>
                            <td>
                                <input class="form-control fw-bold" id="grandTotalInput" disabled />
                            </td>
                            <td></td>
                        </tr>
                    </tfoot>
                </table>
            </div>
        </div>
    </div>

    <button type="submit" class="btn btn-primary me-2">Create</button>
    <a class="btn btn-outline-secondary" asp-page="/Invoices/Index" role="button">Cancel</a>
</form>

<script>
    let itemIndex = @Model.InvoiceDto.Items.Count;

    function addItemRow() {
        const tbody = document.getElementById("itemsBody");

        const row = document.createElement("tr");

        row.innerHTML = `
            <td>
                <input class="form-control"
                       name="InvoiceDto.Items[${itemIndex}].Service" />
            </td>

            <td>
                <input class="form-control unit-price"
                       name="InvoiceDto.Items[${itemIndex}].UnitPrice"
                       value="0.00"
                       type="number"
                       step="0.01"
                       min="0"
                       oninput="updateTotals()" />
            </td>

            <td>
                <input class="form-control quantity"
                       name="InvoiceDto.Items[${itemIndex}].Quantity"
                       value="1"
                       type="number"
                       step="1"
                       min="1"
                       oninput="updateTotals()" />
            </td>

            <td>
                <input class="form-control row-total" disabled />
            </td>

            <td>
                <button type="button" class="btn btn-outline-danger btn-sm" onclick="removeItemRow(this)">
                    Remove
                </button>
            </td>
        `;

        tbody.appendChild(row);
        itemIndex++;
        updateTotals();
    }

    function removeItemRow(button) {
        const tbody = document.getElementById("itemsBody");

        if (tbody.rows.length <= 1) {
            alert("At least one invoice item is required.");
            return;
        }

        button.closest("tr").remove();
        updateTotals();
    }

    function parseNumber(value) {
        return parseFloat((value || "0").toString().replace(",", "."));
    }

    function updateTotals() {
        let grandTotal = 0;

        document.querySelectorAll("#itemsBody tr").forEach(row => {
            const unitPrice = parseNumber(row.querySelector(".unit-price").value);
            const quantity = parseNumber(row.querySelector(".quantity").value);

            let rowTotal = 0;

            if (!isNaN(unitPrice) && !isNaN(quantity)) {
                rowTotal = unitPrice * quantity;
            }

            row.querySelector(".row-total").value = rowTotal.toFixed(2);
            grandTotal += rowTotal;
        });

        document.getElementById("grandTotalInput").value = grandTotal.toFixed(2);
    }

    updateTotals();
</script>