@page "{id:int}"
@model InvoiceApp.Pages.Invoices.EditModel

@{
    var pageTitle = Model.IsDetailsMode
        ? "Invoice Details"
        : Model.IsDeleteMode
            ? "Delete Invoice"
            : "Edit Invoice";

    var isReadOnly = Model.IsDetailsMode || Model.IsDeleteMode;
}

<h2 class="text-center mb-3">@pageTitle</h2>

@if (!ViewData.ModelState.IsValid)
{
    <div class="alert alert-danger">
        Please check the form. At least one invoice item is required.
    </div>
}

@if (Model.IsDetailsMode)
{
    <div class="alert alert-info">
        You are viewing this invoice in details mode. Fields cannot be changed.
    </div>
}
else if (Model.IsDeleteMode)
{
    <div class="alert alert-warning">
        Please review the invoice information before deleting this record.
    </div>
}

<form method="post"
      asp-route-id="@Model.InvoiceId"
      asp-route-mode="@Model.Mode">

    <div class="row g-2 mb-3">
        <div class="col-lg-6">
            <div class="card h-100 border-0 shadow-sm">
                <div class="card-header bg-white fw-semibold">Invoice Details</div>
                <div class="card-body">

                    <div class="row mb-3">
                        <label class="col-sm-4 col-form-label">Invoice Number</label>
                        <div class="col-sm-8">
                            <input class="form-control" asp-for="InvoiceDto.Number" readonly="@isReadOnly" />
                        </div>
                    </div>

                    <div class="row mb-3">
                        <label class="col-sm-4 col-form-label">Status</label>
                        <div class="col-sm-8">
                            @if (isReadOnly)
                            {
                                <input class="form-control" asp-for="InvoiceDto.Status" readonly />
                            }
                            else
                            {
                                <select class="form-select" asp-for="InvoiceDto.Status">
                                    <option value="Pending">Pending</option>
                                    <option value="Paid">Paid</option>
                                </select>
                            }
                        </div>
                    </div>

                    <div class="row mb-3">
                        <label class="col-sm-4 col-form-label">Issue Date</label>
                        <div class="col-sm-8">
                            <input class="form-control" asp-for="InvoiceDto.IssueDate" type="date" readonly="@isReadOnly" />
                        </div>
                    </div>

                    <div class="row mb-3">
                        <label class="col-sm-4 col-form-label">Due Date</label>
                        <div class="col-sm-8">
                            <input class="form-control" asp-for="InvoiceDto.DueDate" type="date" readonly="@isReadOnly" />
                        </div>
                    </div>

                </div>
            </div>
        </div>

        <div class="col-lg-6">
            <div class="card h-100 border-0 shadow-sm">
                <div class="card-header bg-white fw-semibold">Client Details</div>
                <div class="card-body">

                    <div class="row mb-3">
                        <label class="col-sm-4 col-form-label">Client Name</label>
                        <div class="col-sm-8">
                            <input class="form-control" asp-for="InvoiceDto.ClientName" readonly="@isReadOnly" />
                        </div>
                    </div>

                    <div class="row mb-3">
                        <label class="col-sm-4 col-form-label">Email</label>
                        <div class="col-sm-8">
                            <input class="form-control" asp-for="InvoiceDto.Email" readonly="@isReadOnly" />
                        </div>
                    </div>

                    <div class="row mb-3">
                        <label class="col-sm-4 col-form-label">Phone</label>
                        <div class="col-sm-8">
                            <input class="form-control" asp-for="InvoiceDto.Phone" readonly="@isReadOnly" />
                        </div>
                    </div>

                    <div class="row mb-3">
                        <label class="col-sm-4 col-form-label">Address</label>
                        <div class="col-sm-8">
                            <input class="form-control" asp-for="InvoiceDto.Address" readonly="@isReadOnly" />
                        </div>
                    </div>

                </div>
            </div>
        </div>
    </div>

    <div class="card mb-3 border-0 shadow-sm">
        <div class="card-header bg-white d-flex justify-content-between align-items-center">
            <span class="fw-semibold">Invoice Items</span>

            @if (Model.IsEditMode)
            {
                <button type="button" class="btn btn-outline-primary btn-sm" onclick="addItemRow()">
                    + Add Item
                </button>
            }
        </div>

        <div class="card-body">
            <div class="table-responsive">
                <table class="table align-middle" id="itemsTable">
                    <thead class="table-light">
                        <tr>
                            <th style="width: 40%">Service</th>
                            <th style="width: 20%">Unit Price</th>
                            <th style="width: 15%">Quantity</th>
                            <th style="width: 15%">Total</th>
                            @if (Model.IsEditMode)
                            {
                                <th style="width: 10%"></th>
                            }
                        </tr>
                    </thead>

                    <tbody id="itemsBody">
                        @for (int i = 0; i < Model.InvoiceDto.Items.Count; i++)
                        {
                            <tr>
                                <td>
                                    <input class="form-control"
                                           name="InvoiceDto.Items[@i].Service"
                                           value="@Model.InvoiceDto.Items[i].Service"
                                           readonly="@isReadOnly" />
                                </td>

                                <td>
                                    <input class="form-control unit-price"
                                           name="InvoiceDto.Items[@i].UnitPrice"
                                           value="@Model.InvoiceDto.Items[i].UnitPrice.ToString("0.00", System.Globalization.CultureInfo.InvariantCulture)"
                                           type="number"
                                           step="0.01"
                                           min="0"
                                           readonly="@isReadOnly"
                                           oninput="updateTotals()" />
                                </td>

                                <td>
                                    <input class="form-control quantity"
                                           name="InvoiceDto.Items[@i].Quantity"
                                           value="@Model.InvoiceDto.Items[i].Quantity"
                                           type="number"
                                           step="1"
                                           min="1"
                                           readonly="@isReadOnly"
                                           oninput="updateTotals()" />
                                </td>

                                <td>
                                    <input class="form-control row-total" disabled />
                                </td>

                                @if (Model.IsEditMode)
                                {
                                    <td>
                                        <button type="button" class="btn btn-outline-danger btn-sm" onclick="removeItemRow(this)">
                                            Remove
                                        </button>
                                    </td>
                                }
                            </tr>
                        }
                    </tbody>

                    <tfoot>
                        <tr>
                            <td colspan="3" class="text-end fw-bold">Grand Total</td>
                            <td>
                                <input class="form-control fw-bold" id="grandTotalInput" disabled />
                            </td>
                            @if (Model.IsEditMode)
                            {
                                <td></td>
                            }
                        </tr>
                    </tfoot>
                </table>
            </div>
        </div>
    </div>

    @if (Model.IsEditMode)
    {
        <button type="submit" class="btn btn-primary me-2">Save Changes</button>
        <a class="btn btn-outline-secondary" asp-page="/Invoices/Index">Cancel</a>
    }
    else if (Model.IsDetailsMode)
    {
        <a class="btn btn-primary me-2"
           asp-page="/Invoices/Edit"
           asp-route-id="@Model.InvoiceId"
           asp-route-mode="edit">
            Edit This Invoice
        </a>

        <a class="btn btn-outline-secondary" asp-page="/Invoices/Index">Back</a>
    }
    else if (Model.IsDeleteMode)
    {
        <button type="button" class="btn btn-danger me-2" data-bs-toggle="modal" data-bs-target="#deleteModal">
            Delete Invoice
        </button>

        <a class="btn btn-outline-secondary" asp-page="/Invoices/Index">Cancel</a>

        <div class="modal fade" id="deleteModal" tabindex="-1" aria-labelledby="deleteModalLabel" aria-hidden="true">
            <div class="modal-dialog modal-dialog-centered">
                <div class="modal-content">

                    <div class="modal-header bg-danger text-white">
                        <h5 class="modal-title" id="deleteModalLabel">Confirm Delete</h5>
                        <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal" aria-label="Close"></button>
                    </div>

                    <div class="modal-body">
                        <p class="mb-2">Are you sure you want to delete this invoice?</p>

                        <div class="border rounded p-3 bg-light">
                            <p class="mb-1"><strong>Invoice Number:</strong> @Model.InvoiceDto.Number</p>
                            <p class="mb-1"><strong>Client:</strong> @Model.InvoiceDto.ClientName</p>
                            <p class="mb-0"><strong>Total:</strong> <span id="modalTotalPrice"></span></p>
                        </div>

                        <p class="text-muted mt-3 mb-0">
                            This action cannot be undone.
                        </p>
                    </div>

                    <div class="modal-footer">
                        <button type="button" class="btn btn-outline-secondary" data-bs-dismiss="modal">
                            No, Cancel
                        </button>

                        <button type="submit" class="btn btn-danger">
                            Yes, Delete
                        </button>
                    </div>

                </div>
            </div>
        </div>
    }
</form>

<script>
    let itemIndex = @Model.InvoiceDto.Items.Count;
    const isEditMode = "@Model.IsEditMode".toLowerCase() === "true";

    function addItemRow() {
        if (!isEditMode) return;

        const tbody = document.getElementById("itemsBody");
        const row = document.createElement("tr");

        row.innerHTML = `
            <td>
                <input class="form-control"
                       name="InvoiceDto.Items[${itemIndex}].Service" />
            </td>

            <td>
                <input class="form-control unit-price"
                       name="InvoiceDto.Items[${itemIndex}].UnitPrice"
                       value="0.00"
                       type="number"
                       step="0.01"
                       min="0"
                       oninput="updateTotals()" />
            </td>

            <td>
                <input class="form-control quantity"
                       name="InvoiceDto.Items[${itemIndex}].Quantity"
                       value="1"
                       type="number"
                       step="1"
                       min="1"
                       oninput="updateTotals()" />
            </td>

            <td>
                <input class="form-control row-total" disabled />
            </td>

            <td>
                <button type="button" class="btn btn-outline-danger btn-sm" onclick="removeItemRow(this)">
                    Remove
                </button>
            </td>
        `;

        tbody.appendChild(row);
        itemIndex++;
        updateTotals();
    }

    function removeItemRow(button) {
        const tbody = document.getElementById("itemsBody");

        if (tbody.rows.length <= 1) {
            alert("At least one invoice item is required.");
            return;
        }

        button.closest("tr").remove();
        updateTotals();
    }

    function parseNumber(value) {
        return parseFloat((value || "0").toString().replace(",", "."));
    }

    function updateTotals() {
        let grandTotal = 0;

        document.querySelectorAll("#itemsBody tr").forEach(row => {
            const unitPrice = parseNumber(row.querySelector(".unit-price").value);
            const quantity = parseNumber(row.querySelector(".quantity").value);

            let rowTotal = 0;

            if (!isNaN(unitPrice) && !isNaN(quantity)) {
                rowTotal = unitPrice * quantity;
            }

            row.querySelector(".row-total").value = rowTotal.toFixed(2);
            grandTotal += rowTotal;
        });

        document.getElementById("grandTotalInput").value = grandTotal.toFixed(2);

        let modalTotal = document.getElementById("modalTotalPrice");
        if (modalTotal) {
            modalTotal.innerText = grandTotal.toFixed(2) + " $";
        }
    }

    updateTotals();
</script>