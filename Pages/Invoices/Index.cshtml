@page
@model InvoiceApp.Pages.Invoices.IndexModel

@{
    ViewData["Title"] = "Invoices";
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <div>
        <h2 class="fw-bold mb-1">Invoice Management</h2>
        <p class="text-muted mb-0">Manage invoice records, payments and client information.</p>
    </div>

    <a class="btn btn-primary" asp-page="/Invoices/Create">
        + Create New Invoice
    </a>
</div>

<div class="row g-3 mb-4">
    <div class="col-md-3">
        <div class="card border-0 shadow-sm h-100">
            <div class="card-body">
                <p class="text-muted mb-1">Total Invoices</p>
                <h3 class="fw-bold mb-0">@Model.TotalItems</h3>
            </div>
        </div>
    </div>

    <div class="col-md-3">
        <div class="card border-0 shadow-sm h-100">
            <div class="card-body">
                <p class="text-muted mb-1">Paid Invoices</p>
                <h3 class="fw-bold text-success mb-0">@Model.PaidCount</h3>
            </div>
        </div>
    </div>

    <div class="col-md-3">
        <div class="card border-0 shadow-sm h-100">
            <div class="card-body">
                <p class="text-muted mb-1">Pending Invoices</p>
                <h3 class="fw-bold text-warning mb-0">@Model.PendingCount</h3>
            </div>
        </div>
    </div>

    <div class="col-md-3">
        <div class="card border-0 shadow-sm h-100">
            <div class="card-body">
                <p class="text-muted mb-1">Total Amount</p>
                <h3 class="fw-bold mb-0">@Model.TotalRevenue.ToString("N2") $</h3>
            </div>
        </div>
    </div>
</div>

<form method="get" class="card border-0 shadow-sm mb-4">
    <div class="card-body">
        <div class="row g-3 align-items-end">
            <div class="col-md-5">
                <label class="form-label fw-semibold">Search</label>
                <input type="text"
                       name="searchText"
                       value="@Model.SearchText"
                       class="form-control"
                       placeholder="Search invoice number, client, email or service..." />
            </div>

            <div class="col-md-3">
                <label class="form-label fw-semibold">Status</label>
                <select name="statusFilter" class="form-select">
                    <option value="All" selected="@(Model.StatusFilter == "All" || string.IsNullOrEmpty(Model.StatusFilter))">All Statuses</option>
                    <option value="Paid" selected="@(Model.StatusFilter == "Paid")">Paid</option>
                    <option value="Pending" selected="@(Model.StatusFilter == "Pending")">Pending</option>
                </select>
            </div>

            <div class="col-md-2">
                <label class="form-label fw-semibold">Page Size</label>
                <select name="pageSize" class="form-select">
                    <option value="10" selected="@(Model.PageSize == 10)">10</option>
                    <option value="25" selected="@(Model.PageSize == 25)">25</option>
                    <option value="50" selected="@(Model.PageSize == 50)">50</option>
                </select>
            </div>

            <div class="col-md-2 d-flex gap-2">
                <button type="submit" class="btn btn-dark w-100">Apply</button>
                <a class="btn btn-outline-secondary" asp-page="/Invoices/Index">Clear</a>
            </div>
        </div>

        <input type="hidden" name="currentPage" value="1" />
    </div>
</form>

<div class="card border-0 shadow-sm">
    <div class="card-header bg-white d-flex justify-content-between align-items-center">
        <strong>Invoice List</strong>
        <span class="text-muted small">Showing @Model.invoiceList.Count record(s)</span>
    </div>

    <div class="table-responsive">
        <table class="table table-hover align-middle mb-0">
            <thead class="table-light">
                <tr>
                    <th>ID</th>
                    <th>Invoice</th>
                    <th>Status</th>
                    <th>Client</th>
                    <th>Service</th>
                    <th>Total</th>
                    <th>Issue Date</th>
                    <th>Due Date</th>
                    <th class="text-end">Actions</th>
                </tr>
            </thead>

            <tbody>
                @foreach (var invoice in Model.invoiceList)
                {
                    var badgeClass = invoice.Status == "Paid"
                        ? "badge rounded-pill bg-success"
                        : "badge rounded-pill bg-warning text-dark";

                    <tr>
                        <td class="text-muted">#@invoice.Id</td>
                        <td>
                            <strong>@invoice.Number</strong>
                            <div class="small text-muted">@invoice.Email</div>
                        </td>
                        <td>
                            <span class="@badgeClass">@invoice.Status</span>
                        </td>
                        <td>@invoice.ClientName</td>
                        <td>@invoice.Service</td>
                        <td>
                            <strong>@((invoice.UnitPrice * invoice.Quantity).ToString("N2")) $</strong>
                        </td>
                        <td>@invoice.IssueDate?.ToString("dd.MM.yyyy")</td>
                        <td>@invoice.DueDate?.ToString("dd.MM.yyyy")</td>
                        <td class="text-end" style="white-space:nowrap">
                            <a class="btn btn-outline-secondary btn-sm" asp-page="/Invoices/Details" asp-route-id="@invoice.Id">Details</a>
                            <a class="btn btn-outline-primary btn-sm" asp-page="/Invoices/Edit" asp-route-id="@invoice.Id">Edit</a>
                            <a class="btn btn-outline-danger btn-sm" asp-page="/Invoices/Delete" asp-route-id="@invoice.Id">Delete</a>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>

    @if (!Model.invoiceList.Any())
    {
        <div class="alert alert-warning m-3">
            No invoices found for the selected search or filter.
        </div>
    }
</div>

<div class="d-flex justify-content-between align-items-center mt-4">
    <div class="text-muted">
        Total Records: <strong>@Model.TotalItems</strong>
    </div>

    <nav>
        <ul class="pagination mb-0">
            <li class="page-item @(Model.CurrentPage == 1 ? "disabled" : "")">
                <a class="page-link"
                   asp-page="/Invoices/Index"
                   asp-route-currentPage="@(Model.CurrentPage - 1)"
                   asp-route-pageSize="@Model.PageSize"
                   asp-route-searchText="@Model.SearchText"
                   asp-route-statusFilter="@Model.StatusFilter">
                    Previous
                </a>
            </li>

            @for (int i = 1; i <= Model.TotalPages; i++)
            {
                <li class="page-item @(i == Model.CurrentPage ? "active" : "")">
                    <a class="page-link"
                       asp-page="/Invoices/Index"
                       asp-route-currentPage="@i"
                       asp-route-pageSize="@Model.PageSize"
                       asp-route-searchText="@Model.SearchText"
                       asp-route-statusFilter="@Model.StatusFilter">
                        @i
                    </a>
                </li>
            }

            <li class="page-item @(Model.CurrentPage == Model.TotalPages || Model.TotalPages == 0 ? "disabled" : "")">
                <a class="page-link"
                   asp-page="/Invoices/Index"
                   asp-route-currentPage="@(Model.CurrentPage + 1)"
                   asp-route-pageSize="@Model.PageSize"
                   asp-route-searchText="@Model.SearchText"
                   asp-route-statusFilter="@Model.StatusFilter">
                    Next
                </a>
            </li>
        </ul>
    </nav>
</div>